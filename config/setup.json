{
  "version": "1.11",
  "_comment": "Project-wide config. Bump version on any change. See PRD §3.7 / PLAN §5.1.",
  "dataset": {
    "frequencies_hz": [20, 60, 100, 200],
    "amplitude": 1.0,
    "sampling_rate_hz": 1000,
    "duration_seconds": 10,
    "context_window": 10,
    "n_train": 5000,
    "n_val": 1000,
    "n_test": 1000,
    "seed": 42,
    "noise_levels_alpha": [0.01, 0.05, 0.10, 0.20]
  },
  "training": {
    "optimizer": "adam",
    "learning_rate": 0.001,
    "batch_size": 64,
    "max_epochs": 80,
    "early_stopping_patience": 10,
    "num_workers": 0
  },
  "models": {
    "fc":   { "hidden_size": 128, "num_layers": 2, "dropout": 0.2 },
    "rnn":  { "hidden_size": 128, "num_layers": 1, "dropout": 0.0 },
    "lstm": { "hidden_size": 128, "num_layers": 1, "dropout": 0.2 }
  },
  "experiment": {
    "seeds": [42, 123, 7],
    "architectures": ["fc", "rnn", "lstm"],
    "target_frequency_indices": [0, 1, 2, 3]
  },
  "oat_sweep": {
    "hidden_size": [64, 128, 256],
    "num_layers": [1, 2, 3],
    "dropout": [0.0, 0.2, 0.4],
    "learning_rate": [0.0001, 0.001, 0.01]
  },
  "paths": {
    "data_dir": "data",
    "results_dir": "results",
    "logs_dir": "logs"
  }
}
