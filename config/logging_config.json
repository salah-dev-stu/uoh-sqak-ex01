{
  "version": 1,
  "_comment": "Python logging.config.dictConfig schema (version=1 is the API ABI, not project version).",
  "_project_version": "1.00",
  "disable_existing_loggers": false,
  "formatters": {
    "structured": {
      "format": "%(asctime)s %(name)s %(levelname)s %(message)s"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "structured",
      "stream": "ext://sys.stdout"
    }
  },
  "root": {
    "level": "INFO",
    "handlers": ["console"]
  }
}
