# --- Sinusoid Extractor — environment template ---
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# HW1 has no external APIs, so every variable here is OPTIONAL — they exist
# only to satisfy the rubric's "secrets management" requirement (RULES.md §14)
# and to demonstrate the pattern.

# Optional: override default seed at runtime
# SINUSOID_SEED=42

# Optional: override device (cpu / cuda / mps); auto-detected if unset
# SINUSOID_DEVICE=cpu

# Optional: override output directory for results
# SINUSOID_RESULTS_DIR=./results

# Optional: log verbosity (DEBUG / INFO / WARNING / ERROR)
# SINUSOID_LOG_LEVEL=INFO

# --- Reserved for future external services (NOT used in HW1) ---
# SINUSOID_API_KEY=changeme
# SINUSOID_REMOTE_LOG_TOKEN=changeme
